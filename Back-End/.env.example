# =============================================================================
# DWMS Production Environment Variables
# =============================================================================
# Copy this to .env on your production server and fill in real values
# =============================================================================

# Django
DJANGO_SETTINGS_MODULE=config.settings_production
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here

# Database (MySQL)
DB_NAME=dwms
DB_USER=dwms_user
DB_PASSWORD=your-mysql-password
DB_HOST=localhost
DB_PORT=3306

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Encryption (Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-key-here

# Domain
DOMAIN=dwms.run.place
